# Frontend Environment Variables

# API Configuration
REACT_APP_API_URL=http://localhost:8080/api
REACT_APP_WS_URL=ws://localhost:8080/ws

# OAuth Configuration
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id
REACT_APP_FACEBOOK_APP_ID=your-facebook-app-id

# Payment Configuration
REACT_APP_STRIPE_PUBLIC_KEY=your-stripe-public-key

# Application Configuration
REACT_APP_ENVIRONMENT=development
REACT_APP_APP_NAME=IIT JU Alumni Association
REACT_APP_APP_VERSION=1.0.0

# Feature Flags
REACT_APP_ENABLE_VIDEO_CALLS=true
REACT_APP_ENABLE_PAYMENTS=true
REACT_APP_ENABLE_NOTIFICATIONS=true

# File Upload Configuration
REACT_APP_MAX_FILE_SIZE=10485760
REACT_APP_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4

# WebRTC Configuration
REACT_APP_STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

