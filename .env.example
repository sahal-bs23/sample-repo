# Environment Variables for IIT JU Alumni Association

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alumni_db
DB_USERNAME=alumni_user
DB_PASSWORD=alumni_pass

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=iitju-alumni-jwt-secret-key-2024-change-in-production
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@alumni.iitju.edu.bd

# File Storage Configuration
STORAGE_TYPE=LOCAL
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=iitju-alumni-files
AWS_REGION=us-east-1

# Payment Configuration
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Application Configuration
APP_NAME=IIT JU Alumni Association
APP_VERSION=1.0.0
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080
API_URL=http://localhost:8080/api
WS_URL=ws://localhost:8080/ws

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4,application/pdf

# WebRTC Configuration
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
TURN_SERVER_URL=
TURN_SERVER_USERNAME=
TURN_SERVER_PASSWORD=

# Monitoring Configuration
GRAFANA_PASSWORD=admin
PROMETHEUS_ENABLED=false

# Feature Flags
ENABLE_VIDEO_CALLS=true
ENABLE_PAYMENTS=true
ENABLE_NOTIFICATIONS=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_ADMIN_APPROVAL=false

# Development Configuration
DEBUG_MODE=true
LOG_LEVEL=INFO
PROFILE=development

